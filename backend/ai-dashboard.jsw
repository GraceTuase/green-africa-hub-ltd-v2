// Helper functions to get member data
function getMemberHistoricalData(memberId) {
    return wixData.query('MembersProfile')
        .eq('uniqueMemberId', memberId)
        .limit(1)
        .find()
        .then(results => {
            if (results.items.length === 0) {
                throw new Error('Member not found');
            }
            return results.items[0];
        });
}

function getExtendedHistoricalData(memberId, days) {
    const startDate = new Date(Date.now() - (days * 24 * 60 * 60 * 1000));
    
    return wixData.query('UsageLogs')
        .eq('memberId', memberId)
        .ge('timestamp', startDate)
        .find()
        .then(results => {
            return {
                memberId: memberId,
                period: days,
                usageLogs: results.items,
                startDate: startDate,
                endDate: new Date()
            };
        });
}

function getUsageLogs(memberId, days) {
    const startDate = new Date(Date.now() - (days * 24 * 60 * 60 * 1000));
    
    return wixData.query('UsageLogs')
        .eq('memberId', memberId)
        .ge('timestamp', startDate)
        .find()
        .then(results => results.items);
}

function getBusinessActivities(memberId) {
    return wixData.query('UsageLogs')
        .eq('memberId', memberId)
        .contains('compliance', 'BUSINESS')
        .descending('timestamp')
        .limit(50)
        .find()
        .then(results => results.items);
}

// Import required functions
import { getCarbonImpactDashboard } from './carbon-impact';
import { getReferralStats } from './referral';
