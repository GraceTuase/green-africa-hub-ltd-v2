// Backend: security.jsw - Professional Tool Gating System
import wixData from 'wix-data';
import { checkFeatureAccess } from './events';

// Cookbook Gate - Block GAH-C (Basic) users from /digital-cookbook
export function checkCookbookAccess(memberId) {
    return wixData.query('MembersProfile')
        .eq('uniqueMemberId', memberId)
        .limit(1)
        .find()
        .then(results => {
            if (results.items.length === 0) {
                return { 
                    allowed: false, 
                    redirectUrl: '/signup', 
                    message: 'Member not found' 
                };
            }
            
            const member = results.items[0];
            const memberTier = member.tier;
            
            // STRICT GATE: Basic users blocked from cookbook
            if (memberTier === 'basic') {
                return {
                    allowed: false,
                    redirectUrl: '/upgrade',
                    message: 'Digital Cookbook requires Pro membership or higher. Upgrade to access 50+ sustainable recipes.',
                    currentTier: memberTier,
                    requiredTier: 'pro',
                    blockedFeature: 'digital_cookbook'
                };
            }
            
            // Allow access for Pro, Pro Plus, Enterprise
            return {
                allowed: true,
                memberId: memberId,
                tier: memberTier,
                message: 'Digital Cookbook access granted'
            };
        });
}

