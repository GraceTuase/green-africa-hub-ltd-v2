// Registry Trust Score Check
export function checkTrustScore(memberId, minimumScore = 80) {
    return wixData.query('MembersProfile')
        .eq('uniqueMemberId', memberId)
        .limit(1)
        .find()
        .then(results => {
            if (results.items.length === 0) {
                return { 
                    trusted: false, 
                    message: 'Member not found' 
                };
            }
            
            const member = results.items[0];
            const trustScore = member.trustScore || 0;
            
            if (trustScore < minimumScore) {
                return {
                    trusted: false,
                    trustScore: trustScore,
                    minimumScore: minimumScore,
                    message: `Trust score ${trustScore} below minimum ${minimumScore}. Complete compliance activities to improve.`
                };
            }
            
            return {
                trusted: true,
                trustScore: trustScore,
                message: 'Registry trust verified'
            };
        });
}

// Comprehensive access check for dashboard
export function getMemberAccessProfile(memberId) {
    return Promise.all([
        checkCookbookAccess(memberId),
        checkBusinessSuiteAccess(memberId),
        checkSupplierAccess(memberId),
        checkMultiStaffAccess(memberId),
        checkAuditAccess(memberId),
        checkTrustScore(memberId)
    ]).then(results => {
        return {
            memberId: memberId,
            cookbookAccess: results[0],
            businessSuiteAccess: results[1],
            supplierAccess: results[2],
            multiStaffAccess: results[3],
            auditAccess: results[4],
            trustStatus: results[5],
            overallAccess: results.every(r => r.allowed || r.trusted !== false)
        };
    });
}
