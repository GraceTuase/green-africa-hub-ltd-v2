// Backend: sms.jsw - SMS API Integration for Carbon Badge Notifications
import wixData from 'wix-data';
import fetch from 'node-fetch';

// SMS Configuration (replace with your SMS provider details)
const SMS_CONFIG = {
    apiKey: 'YOUR_SMS_API_KEY', // Replace with actual API key
    apiUrl: 'https://api.sms-provider.com/send', // Replace with actual SMS API URL
    senderId: 'GAHHub', // Your sender ID
    carbonBadgeTemplate: '🌱 Green Africa Hub: Your Carbon Badge is ready! View your sustainability impact: {badgeUrl} - Track your green journey with GAH.'
};

// Send Carbon Badge SMS to Pro+ members
export function sendCarbonBadgeSMS(memberId, carbonData) {
    return wixData.query('MembersProfile')
        .eq('uniqueMemberId', memberId)
        .limit(1)
        .find()
        .then(results => {
            if (results.items.length === 0) {
                throw new Error('Member not found');
            }
            
            const member = results.items[0];
            
            // Check if member is Pro+ tier (eligible for SMS notifications)
            const eligibleTiers = ['pro', 'proplus', 'enterprise'];
            if (!eligibleTiers.includes(member.tier)) {
                return {
                    success: false,
                    message: 'SMS notifications available for Pro+ members only',
                    tier: member.tier
                };
            }
            
            // Check if member has phone number
            if (!member.phoneNumber) {
                return {
                    success: false,
                    message: 'No phone number on file for SMS notifications'
                };
            }
            
            // Generate carbon badge URL
            const badgeUrl = `https://www.greenafricahub.org/carbon-badge/${memberId}`;
            
            // Prepare SMS message
            const message = SMS_CONFIG.carbonBadgeTemplate
                .replace('{badgeUrl}', badgeUrl)
                .replace('{carbonSaved}', carbonData.monthlyCarbonSaved.toFixed(2))
                .replace('{memberName}', member.name || 'Member');
            
            // Send SMS via API
            return sendSMS(member.phoneNumber, message);
        })
        .then(smsResult => {
            if (smsResult.success) {
                // Log SMS sent
                return wixData.insert('UsageLogs', {
                    logId: `SMS-${Date.now()}`,
                    memberId: memberId,
                    action: 'CARBON_BADGE_SMS_SENT',
                    timestamp: new Date(),
                    compliance: 'MEMBER_NOTIFICATION',
                    registryTrust: true,
                    smsStatus: 'sent',
                    carbonData: JSON.stringify(carbonData)
                });
            }
            return smsResult;
        })
        .then(() => {
            return {
                success: true,
                message: 'Carbon Badge SMS sent successfully'
            };
        })
        .catch(error => {
            console.error('SMS sending error:', error);
            return {
                success: false,
                message: 'Failed to send SMS notification'
            };
        });
}

