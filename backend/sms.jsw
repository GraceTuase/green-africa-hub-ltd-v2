// Send SMS for sustainable batch logging (Pro+ feature)
export function sendSustainableBatchSMS(memberId, batchData) {
    return wixData.query('MembersProfile')
        .eq('uniqueMemberId', memberId)
        .limit(1)
        .find()
        .then(results => {
            if (results.items.length === 0) {
                throw new Error('Member not found');
            }
            
            const member = results.items[0];
            
            // Check if member is Pro+ tier
            const eligibleTiers = ['proplus', 'enterprise'];
            if (!eligibleTiers.includes(member.tier)) {
                return {
                    success: false,
                    message: 'Sustainable batch SMS available for Pro+ and Enterprise members only',
                    tier: member.tier
                };
            }
            
            if (!member.phoneNumber) {
                return {
                    success: false,
                    message: 'No phone number on file for SMS notifications'
                };
            }
            
            // Prepare sustainable batch message
            const message = `🌿 Green Africa Hub: Great work! Your sustainable batch saved {carbonSaved}kg CO₂. View details: {batchUrl} - Leading the way in sustainable catering!`;
            
            const badgeUrl = `https://www.greenafricahub.org/sustainable-batch/${batchData.batchId}`;
            const formattedMessage = message
                .replace('{carbonSaved}', batchData.carbonSaved.toFixed(2))
                .replace('{batchUrl}', badgeUrl);
            
            return sendSMS(member.phoneNumber, formattedMessage);
        })
        .then(smsResult => {
            if (smsResult.success) {
                // Log SMS sent
                return wixData.insert('UsageLogs', {
                    logId: `SMS-BATCH-${Date.now()}`,
                    memberId: memberId,
                    action: 'SUSTAINABLE_BATCH_SMS_SENT',
                    timestamp: new Date(),
                    compliance: 'SUSTAINABILITY_ALERT',
                    registryTrust: true,
                    smsStatus: 'sent',
                    batchData: JSON.stringify(batchData)
                });
            }
            return smsResult;
        })
        .then(() => {
            return {
                success: true,
                message: 'Sustainable batch SMS sent successfully'
            };
        })
        .catch(error => {
            console.error('Batch SMS sending error:', error);
            return {
                success: false,
                message: 'Failed to send sustainable batch SMS'
            };
        });
}

// Get SMS notification preferences for member
export function getSMSNotificationSettings(memberId) {
    return wixData.query('MembersProfile')
        .eq('uniqueMemberId', memberId)
        .limit(1)
        .find()
        .then(results => {
            if (results.items.length === 0) {
                throw new Error('Member not found');
            }
            
            const member = results.items[0];
            const eligibleTiers = ['pro', 'proplus', 'enterprise'];
            const isEligible = eligibleTiers.includes(member.tier);
            
            return {
                memberId: memberId,
                tier: member.tier,
                isEligibleForSMS: isEligible,
                phoneNumber: member.phoneNumber || null,
                smsEnabled: member.smsEnabled || false,
                carbonBadgeNotifications: member.carbonBadgeNotifications !== false, // Default to true
                sustainableBatchNotifications: member.sustainableBatchNotifications !== false // Default to true
            };
        });
}

// Update SMS notification preferences
export function updateSMSNotificationSettings(memberId, settings) {
    return wixData.query('MembersProfile')
        .eq('uniqueMemberId', memberId)
        .limit(1)
        .find()
        .then(results => {
            if (results.items.length === 0) {
                throw new Error('Member not found');
            }
            
            const member = results.items[0];
            
            // Update SMS settings
            return wixData.update('MembersProfile', member._id, {
                phoneNumber: settings.phoneNumber || member.phoneNumber,
                smsEnabled: settings.smsEnabled !== undefined ? settings.smsEnabled : member.smsEnabled,
                carbonBadgeNotifications: settings.carbonBadgeNotifications !== undefined ? settings.carbonBadgeNotifications : member.carbonBadgeNotifications,
                sustainableBatchNotifications: settings.sustainableBatchNotifications !== undefined ? settings.sustainableBatchNotifications : member.sustainableBatchNotifications
            });
        })
        .then(() => {
            return {
                success: true,
                message: 'SMS notification settings updated successfully'
            };
        })
        .catch(error => {
            return {
                success: false,
                message: 'Failed to update SMS settings'
            };
        });
}

// Get SMS usage statistics for Enterprise
export function getSMSUsageStats(parentId) {
    return wixData.query('UsageLogs')
        .contains('memberId', parentId) // Matches parent and all staff
        .contains('action', 'SMS')
        .between('timestamp', new Date(Date.now() - 30 * 24 * 60 * 60 * 1000), new Date()) // Last 30 days
        .find()
        .then(results => {
            const carbonBadgeSMS = results.items.filter(log => log.action === 'CARBON_BADGE_SMS_SENT').length;
            const batchSMS = results.items.filter(log => log.action === 'SUSTAINABLE_BATCH_SMS_SENT').length;
            const totalSMS = results.items.length;
            
            return {
                parentId: parentId,
                period: 'Last 30 days',
                totalSMS: totalSMS,
                carbonBadgeSMS: carbonBadgeSMS,
                sustainableBatchSMS: batchSMS,
                averageSMSPerDay: (totalSMS / 30).toFixed(1)
            };
        });
}
