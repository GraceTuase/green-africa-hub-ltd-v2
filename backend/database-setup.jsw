// Backend: database-setup.jsw - Database Collection Setup Scripts
import wixData from 'wix-data';

// Initialize all database collections for Green Africa Hub Registry of Trust
export function initializeDatabaseCollections() {
    console.log('Initializing Green Africa Hub Registry of Trust database collections...');
    
    const setupPromises = [
        setupMembersProfileCollection(),
        setupHeritageCookbookCollection(),
        setupDailyMenuCollection(),
        setupSupplierLedgerCollection(),
        setupUsageLogsCollection()
    ];
    
    return Promise.all(setupPromises)
        .then(results => {
            console.log('All database collections initialized successfully');
            return {
                success: true,
                message: 'Registry of Trust database collections initialized',
                collections: results.map(r => r.collection),
                timestamp: new Date()
            };
        })
        .catch(error => {
            console.error('Database initialization failed:', error);
            throw new Error(`Database setup failed: ${error.message}`);
        });
}

// Setup MembersProfile Collection
export function setupMembersProfileCollection() {
    console.log('Setting up MembersProfile collection...');
    
    // Create sample member to verify collection structure
    const sampleMember = {
        uniqueMemberId: 'GAH-C-26-0001',
        tier: 'basic',
        monthlyMealCredits: 3,
        lifetimeCarbonSaved: 0,
        attendanceStatus: 'Available',
        checkInDate: null,
        usageLogs: 0,
        parentId: null,
        allergenSettings: JSON.stringify({
            gluten: false,
            dairy: false,
            eggs: false,
            soy: false,
            peanuts: false,
            treeNuts: false,
            shellfish: false,
            fish: false,
            sesame: false,
            mustard: false,
            celery: false,
            lupin: false,
            molluscs: false,
            sulphites: false
        }),
        qrCodeUrl: 'https://www.greenafricahub.org/registry/GAH-C-26-0001',
        createdAt: new Date(),
        email: 'sample@greenafricahub.org.uk',
        name: 'Sample Member',
        registryCompliance: true,
        trustScore: 100,
        verificationStatus: 'verified',
        lastActivity: new Date()
    };
    
    return wixData.insert('MembersProfile', sampleMember)
        .then(result => {
            console.log('MembersProfile collection setup complete');
            return {
                collection: 'MembersProfile',
                status: 'created',
                sampleId: result.uniqueMemberId
            };
        })
        .catch(error => {
            // If collection already exists, that's fine
            if (error.message.includes('already exists')) {
                console.log('MembersProfile collection already exists');
                return {
                    collection: 'MembersProfile',
                    status: 'exists'
                };
            }
            throw error;
        });
}

