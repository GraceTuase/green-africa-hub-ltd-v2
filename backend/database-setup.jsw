// Setup DailyMenu Collection
export function setupDailyMenuCollection() {
    console.log('Setting up DailyMenu collection...');
    
    const sampleDailyMenu = {
        currentRecipes: JSON.stringify([
            { recipeName: 'Jollof Rice', quantity: 2 },
            { recipeName: 'Efo Riro', quantity: 1 },
            { recipeName: 'Pounded Yam', quantity: 1 }
        ]),
        eventDate: new Date(),
        totalCarbonBaseline: 19.2,
