// Verify database collections exist and are accessible
export function verifyDatabaseCollections() {
    console.log('Verifying database collections...');
    
    const verificationPromises = [
        wixData.query('MembersProfile').find(),
        wixData.query('HeritageCookbook').find(),
        wixData.query('DailyMenu').find(),
        wixData.query('SupplierLedger').find(),
        wixData.query('UsageLogs').find()
    ];
    
    return Promise.all(verificationPromises)
        .then(results => {
            const verification = {
                MembersProfile: { exists: true, count: results[0].totalCount },
                HeritageCookbook: { exists: true, count: results[1].totalCount },
                DailyMenu: { exists: true, count: results[2].totalCount },
                SupplierLedger: { exists: true, count: results[3].totalCount },
                UsageLogs: { exists: true, count: results[4].totalCount }
            };
            
            console.log('Database verification complete:', verification);
            
            return {
                success: true,
                message: 'All database collections verified',
                collections: verification,
                timestamp: new Date()
            };
        })
        .catch(error => {
            console.error('Database verification failed:', error);
            throw new Error(`Database verification failed: ${error.message}`);
        });
}

// Clean up sample data (for production)
export function cleanupSampleData() {
    console.log('Cleaning up sample data...');
    
    const cleanupPromises = [
        wixData.query('MembersProfile').eq('email', 'sample@greenafricahub.org.uk').remove(),
        wixData.query('HeritageCookbook').remove(),
        wixData.query('DailyMenu').remove(),
        wixData.query('SupplierLedger').remove(),
        wixData.query('UsageLogs').remove()
    ];
    
    return Promise.all(cleanupPromises)
        .then(results => {
            console.log('Sample data cleanup complete');
            return {
                success: true,
                message: 'Sample data cleaned up',
                timestamp: new Date()
            };
        })
        .catch(error => {
            console.error('Sample data cleanup failed:', error);
            throw new Error(`Sample data cleanup failed: ${error.message}`);
        });
}

// Get database statistics
export function getDatabaseStatistics() {
    console.log('Getting database statistics...');
    
    const statsPromises = [
        wixData.query('MembersProfile').find(),
        wixData.query('HeritageCookbook').find(),
        wixData.query('DailyMenu').find(),
        wixData.query('SupplierLedger').find(),
        wixData.query('UsageLogs').find()
    ];
    
    return Promise.all(statsPromises)
        .then(results => {
            const stats = {
                members: results[0].totalCount,
                recipes: results[1].totalCount,
                dailyMenus: results[2].totalCount,
                suppliers: results[3].totalCount,
                usageLogs: results[4].totalCount,
                totalCarbonSaved: results[4].items
                    .filter(log => log.action === 'CARBON_SAVINGS')
                    .reduce((sum, log) => sum + (log.carbonAmount || 0), 0),
                lastUpdated: new Date()
            };
            
            return {
                success: true,
                statistics: stats,
                message: 'Database statistics retrieved'
            };
        })
        .catch(error => {
            console.error('Database statistics failed:', error);
            throw new Error(`Database statistics failed: ${error.message}`);
        });
}
